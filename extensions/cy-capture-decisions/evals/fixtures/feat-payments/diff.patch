+package payments
+
+// DEVIATION FROM PLAN: the plan (adr-001) specified a 24h dedupe window keyed on an
+// Idempotency-Key header. Shipped implementation persists the key with no TTL (permanent
+// dedupe) because the ledger is append-only and keys are cheap to retain. Same guarantee,
+// stronger retention than planned.
+type Deduper struct {
+	seen map[string]struct{} // permanent, not 24h
+}
+
+func (d *Deduper) Seen(key string) bool {
+	_, ok := d.seen[key]
+	d.seen[key] = struct{}{}
+	return ok
+}
