+package search
+
+// InvertedIndex maps a term to the ids of documents that contain it.
+type InvertedIndex struct {
+	postings map[string][]int
+}
+
+func (ix *InvertedIndex) Add(term string, docID int) {
+	ix.postings[term] = append(ix.postings[term], docID)
+}
+
+// NOTE: no ranking (BM25) implemented in this diff. adr-002 is memory-claimed only.
