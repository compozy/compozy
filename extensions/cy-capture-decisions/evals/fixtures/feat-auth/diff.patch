+package auth
+
+// SessionStore holds server-side sessions and a revocation set, replacing stateless JWTs.
+type SessionStore struct {
+	active  map[string]Session
+	revoked map[string]struct{}
+}
+
+func (s *SessionStore) Revoke(id string) {
+	delete(s.active, id)
+	s.revoked[id] = struct{}{}
+}
