        <mxCell id="noteArtifacts" value="Every artifact stays in plain markdown, so you can diff, edit, and version-control the workflow between steps." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#93c5fd;fontColor=#1e3a8a;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1640" width="760" height="78" as="geometry" />
        </mxCell>
        <mxCell id="noteMetadata" value="Task and review issue files use YAML frontmatter for parseable metadata such as status, domain, severity, and provider_ref." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#fcd34d;fontColor=#854d0e;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1740" width="760" height="78" as="geometry" />
        </mxCell>
        <mxCell id="noteRepeat" value="Repeat the execution and review loop until the workflow is clean, then archive and ship." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#86efac;fontColor=#166534;spacing=10;" vertex="1" parent="1">
