        <mxCell id="artifactReviews" value=".compozy/tasks/user-auth/reviews-001/" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fdba74;fontColor=#9a3412;" vertex="1" parent="1">
